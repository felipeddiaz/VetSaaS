DEBUG=False
SECRET_KEY=cambia-esto-por-una-clave-segura-en-produccion
ALLOWED_HOSTS=tu-dominio.railway.app

PGDATABASE=veterinaria_saas
PGUSER=postgres
PGPASSWORD=TU_PASSWORD_AQUI
PGHOST=localhost
PGPORT=5432

# Sentry — dejar vacío en dev, poner DSN de producción
# Obtener en: https://sentry.io → tu proyecto → Settings → Client Keys → DSN
SENTRY_DSN=

# Security headers — activar en producción (dejar en False en dev)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
